# Copy this file to `.env` and fill in the real values before running builds
# Example PostgreSQL connection string (replace placeholders):
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# If your runtime and Prisma use the same connection, set DIRECT_URL to the same value.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DIRECT_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public

# For SQLite example:
# DATABASE_URL=file:./dev.db
# DIRECT_URL=file:./dev.db

# Note: Do NOT commit real credentials. Copy to `.env` and keep that out of VCS.